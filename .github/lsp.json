{
  "lspServers": {
    "typescript": {
      "command": "npx",
      "args": ["-y", "typescript-language-server", "--stdio"],
      "fileExtensions": {
        ".ts": "typescript",
        ".tsx": "typescriptreact",
        ".js": "javascript",
        ".jsx": "javascriptreact",
        ".mjs": "javascript",
        ".cjs": "javascript"
      }
    },
    "angular": {
      "command": "./.github/scripts/ngserver-launch.sh",
      "args": [],
      "fileExtensions": {
        ".html": "html",
        ".ng.html": "html"
      }
    },
    "html-css-json": {
      "command": "npx",
      "args": ["-y", "--package=vscode-langservers-extracted", "vscode-html-language-server", "--stdio"],
      "fileExtensions": {
        ".html": "html"
      }
    },
    "css": {
      "command": "npx",
      "args": ["-y", "--package=vscode-langservers-extracted", "vscode-css-language-server", "--stdio"],
      "fileExtensions": {
        ".css": "css",
        ".scss": "scss"
      }
    },
    "json": {
      "command": "npx",
      "args": ["-y", "--package=vscode-langservers-extracted", "vscode-json-language-server", "--stdio"],
      "fileExtensions": {
        ".json": "json",
        ".jsonc": "jsonc"
      }
    },
    "yaml": {
      "command": "npx",
      "args": ["-y", "yaml-language-server", "--stdio"],
      "fileExtensions": {
        ".yml": "yaml",
        ".yaml": "yaml"
      }
    }
  }
}
